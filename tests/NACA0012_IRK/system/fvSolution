FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(p|p_rgh|G)"
    {
        solver           GAMG;
        tolerance        0;
        relTol           0.01;
        smoother         GaussSeidel;
        maxIter          10;
    }

    "(p|p_rgh|G)Final"
    {
        $p;
        relTol          0;
        tolerance       1e-8;
    }

    "(U|T|e|h|nuTilda|k|omega|epsilon)"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       0;
        relTol          0.01;
        maxIter         10;
    }

    "(U|T|e|h|nuTilda|k|omega|epsilon)Final"
    {
        $U;
        relTol          0;
    }
}

relaxationFactors
{
    fields
    {
        "(p|p_rgh|G)"                   1.0;
    }
    equations
    {
        "(U|T|e|h|nuTilda|k|omega|epsilon)"                   1.0;
    }
}

PIMPLE
{
    nNonOrthogonalCorrectors 0;
    nCorrectors         2;
    nOuterCorrectors 50;

    residualControl
    {
        "(U|T|e|h|nuTilda|k|omega|epsilon|p|p_rgh|G)" 
        {
            tolerance       1e-8; 
            relTol          1e-8; 
        } 
    }
}



